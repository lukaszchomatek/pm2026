{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["k6", "loadtest", "demo"],
  "title": "PM2026 k6 Load Tests",
  "uid": "pm2026-k6",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "testid",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(k6_demo_posts_created_total, k6_testid)",
        "query": {
          "query": "label_values(k6_demo_posts_created_total, k6_testid)"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Posts created",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(k6_demo_posts_created_total{k6_testid=~\"$testid\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Post create failed",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(k6_demo_post_create_failed_total{k6_testid=~\"$testid\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Create posts RPS",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total{k6_endpoint=\"posts_create\",k6_testid=~\"$testid\"}[1m]))",
          "legendFormat": "posts_create rps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP req duration (posts_create)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_p95{k6_endpoint=\"posts_create\",k6_testid=~\"$testid\"})",
          "legendFormat": "p95"
        },
        {
          "expr": "avg(k6_http_req_duration_p99{k6_endpoint=\"posts_create\",k6_testid=~\"$testid\"})",
          "legendFormat": "p99"
        },
        {
          "expr": "avg(k6_http_req_duration_avg{k6_endpoint=\"posts_create\",k6_testid=~\"$testid\"})",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Moderation decision duration",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(k6_demo_moderation_decision_duration_avg{k6_testid=~\"$testid\"})",
          "legendFormat": "avg"
        },
        {
          "expr": "avg(k6_demo_moderation_decision_duration_p95{k6_testid=~\"$testid\"})",
          "legendFormat": "p95"
        },
        {
          "expr": "max(k6_demo_moderation_decision_duration_max{k6_testid=~\"$testid\"})",
          "legendFormat": "max"
        }
      ]
    }
  ]
}