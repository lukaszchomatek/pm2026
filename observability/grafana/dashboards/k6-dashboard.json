{
  "annotations": {"list": []},
  "editable": true,
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["k6", "loadtest", "demo"],
  "title": "PM2026 k6 Load Tests",
  "uid": "pm2026-k6",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "testid",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(demo_posts_created, testid)",
        "query": {"query": "label_values(demo_posts_created, testid)"},
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Posts created",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(demo_posts_created{testid=~\"$testid\"})"}]
    },
    {
      "type": "stat",
      "title": "Post create failed",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(demo_post_create_failed{testid=~\"$testid\"})"}]
    },
    {
      "type": "timeseries",
      "title": "Create posts RPS",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total{endpoint=\"posts_create\",testid=~\"$testid\"}[1m]))",
          "legendFormat": "posts_create rps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP req duration (posts_create)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(k6_http_req_duration_seconds_bucket{endpoint=\"posts_create\",testid=~\"$testid\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(k6_http_req_duration_seconds_bucket{endpoint=\"posts_create\",testid=~\"$testid\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Moderation decision duration",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "avg(demo_moderation_decision_duration{testid=~\"$testid\"})",
          "legendFormat": "avg"
        },
        {
          "expr": "max(demo_moderation_decision_duration{testid=~\"$testid\"})",
          "legendFormat": "max"
        }
      ]
    }
  ]
}
